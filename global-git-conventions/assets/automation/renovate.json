{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "mode": "full",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchDepNames": ["mcp-foundation"],
      "groupName": "mcp-foundation",
      "addLabels": ["foundation"],
      "commitMessagePrefix": "fix(deps):"
    }
  ]
}
